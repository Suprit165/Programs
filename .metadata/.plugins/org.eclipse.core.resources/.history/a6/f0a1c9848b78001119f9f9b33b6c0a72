interface Calculator
{
	void add();
	void sub();
	
}

class MyCalc1 implements Calculator
{
	public void add()
	{
		int a = 200;
		int b = 100;
		System.out.println(a+b);
	}
	
	public void sub()
	{
		int a = 200;
		int b = 100;
		System.out.println(a-b);
	}
	
	public void mul()
	{
		int a = 200;
		int b = 100;
		System.out.println(a*b);
	}
}

